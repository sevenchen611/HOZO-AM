# Secure control API for proactive LINE push messages.
HOZO_CONTROL_API_KEY=<HOZO_CONTROL_API_KEY>

# User UI login for browser-based project/task editing.
HOZO_USER_UI_USERNAME=<HOZO_USER_UI_USERNAME>
HOZO_USER_UI_PASSWORD=<HOZO_USER_UI_PASSWORD>

# Optional cron tracing / alerting.
CONTROL_LINE_PUSH_URL=https://hozo-am-line-oa-webhook.onrender.com/control/line/push
CRON_JOB_NAME=
HOZO_CRON_ALERTS_ENABLED=true

# Optional fallback target for morning/evening reports.
# If omitted, the service auto-resolves the latest personal owner conversation from Notion.
HOZO_REPORT_TARGET_ID=
HOZO_REPORT_TARGET_TYPE=user
HOZO_REPORT_TARGET_NAME_KEYWORD=Maggie

# Optional public report URLs.
HOZO_PUBLIC_BASE_URL=https://hozo-am-line-oa-webhook.onrender.com
MORNING_BRIEF_URL=
DAILY_REPORT_URL=
FOLLOWUP_CONFIRMATION_URL=

# Optional 08:00 report Google Calendar input.
# Use one of these until the production Google Calendar OAuth connector is wired into HOZO AM.
HOZO_REPORT_TIMEZONE=Asia/Taipei
HOZO_GOOGLE_CALENDAR_EVENTS_JSON=
HOZO_GOOGLE_CALENDAR_EVENTS_FILE=
