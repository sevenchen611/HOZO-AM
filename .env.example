PORT=3002

# Notion storage.
NOTION_TOKEN=
HOZO_CONVERSATIONS_DATA_SOURCE_ID=
HOZO_MESSAGES_DATA_SOURCE_ID=
HOZO_ATTACHMENTS_DATA_SOURCE_ID=
